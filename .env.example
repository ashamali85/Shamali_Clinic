# ---------------------------------------------------------------------------
# Dr. Shamali Gastroenterology Clinic — environment configuration
# ---------------------------------------------------------------------------
# These are the variables to set in Vercel (Settings -> Environment Variables).

# PostgreSQL. Use a hosted provider (Neon, Supabase, Vercel Postgres, etc).
#   DATABASE_URL -> the POOLED connection string (used at runtime)
#   DIRECT_URL   -> the DIRECT / non-pooled string (used by Prisma for db push)
# On Neon: DATABASE_URL uses the "-pooler" host; DIRECT_URL uses the plain host.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/shamali_clinic?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/shamali_clinic?sslmode=require"

# Session signing secret. MUST be at least 32 characters.
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
