# ---------------------------------------------------------------------------
# Dr. Shamali Gastroenterology Clinic — environment configuration
# ---------------------------------------------------------------------------

# Database. Ships with SQLite for zero-setup local development.
# For production, switch the datasource provider in prisma/schema.prisma to
# "postgresql" and point DATABASE_URL at your Postgres/Neon instance.
DATABASE_URL="file:./dev.db"

# Session signing secret. MUST be at least 32 characters.
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

APP_URL="http://localhost:3000"
